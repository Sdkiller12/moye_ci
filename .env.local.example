# Copy this file to .env and fill in your actual values

# Environment
NODE_ENV=development
PORT=3000

# Supabase Configuration
# 1. Go to https://app.supabase.com
# 2. Create a new project or select existing
# 3. Go to Settings > API
# 4. Copy the URL and anon/public key
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# Gemini AI Configuration
# 1. Go to https://makersuite.google.com/app/apikey
# 2. Create a new API key
# 3. Copy the key here
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LibreTranslate Configuration
# This runs locally via Docker (see docker-compose.yml)
# No configuration needed unless you're using a remote instance
LIBRETRANSLATE_URL=http://localhost:5000

# Supabase Storage (optional)
# Bucket name for cultural media uploads
# Create this bucket in Supabase Storage dashboard
SUPABASE_STORAGE_BUCKET=moye-media
